{
  "id": "case-001-database-timeout",
  "question": "Investigue por que o checkout-api teve aumento de erro 5xx entre 10h e 10h30 em 2026-07-08",
  "expected_findings": [
    "DatabaseTimeoutException",
    "p99",
    "deploy",
    "POST /checkout",
    "connection pool"
  ],
  "must_not_include": [
    "certeza absoluta",
    "reiniciar automaticamente",
    "rollback executado",
    "drop table"
  ],
  "expected_trajectory": {
    "required_calls": [
      { "id": "error_summary", "tool": "get_error_summary", "params": { "service": "checkout-api" }, "max_occurrences": 1 },
      { "id": "top_exceptions", "tool": "get_top_exceptions", "params": { "service": "checkout-api" }, "max_occurrences": 1 },
      { "id": "error_logs", "tool": "get_recent_logs", "params": { "service": "checkout-api", "level": "ERROR" }, "max_occurrences": 1 },
      { "id": "latency_incident", "tool": "get_latency_summary", "params": { "service": "checkout-api", "from": "2026-07-08T10:00:00-03:00", "to": "2026-07-08T10:30:00-03:00" }, "max_occurrences": 1 },
      { "id": "latency_baseline", "tool": "get_latency_summary", "params": { "service": "checkout-api", "from": "2026-07-08T09:30:00-03:00", "to": "2026-07-08T10:00:00-03:00" }, "max_occurrences": 1 },
      { "id": "deploy_window", "tool": "get_deployment_events", "params": { "service": "checkout-api" }, "max_occurrences": 1 },
      { "id": "knowledge_search", "tool": "search_runbooks", "params": {}, "max_occurrences": 1 },
      { "id": "runbook", "tool": "get_runbook", "params": {}, "max_occurrences": 1 }
    ],
    "order_constraints": [
      { "before": "error_summary", "after": "knowledge_search" },
      { "before": "latency_incident", "after": "knowledge_search" },
      { "before": "deploy_window", "after": "runbook" }
    ],
    "forbid_exact_duplicates": true,
    "max_calls": 12
  }
}
