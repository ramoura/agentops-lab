{
  "name": "agentops-lab",
  "version": "0.1.0",
  "private": true,
  "description": "AgentOps Lab — Incident Investigation Assistant (PoC de estudo: MCP, skills, evals, segurança read-only)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "mcp-servers/*",
    "apps/*",
    "evals"
  ],
  "scripts": {
    "investigate": "tsx apps/cli-agent/src/main.ts",
    "eval": "tsx evals/src/runner.ts",
    "eval:llm": "tsx evals/src/runner.ts --engine=llm",
    "compare": "tsx evals/src/compare-runner.ts",
    "eval:redteam": "tsx evals/src/redteam-runner.ts --engine=llm",
    "trace:view": "tsx apps/cli-agent/src/trace-view.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^4.1.10",
    "execa": "^9.6.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.10"
  }
}
